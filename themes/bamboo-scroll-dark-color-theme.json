  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#8E8578",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#D4A857"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.return"
      ],
      "settings": {
        "foreground": "#D4A857",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface"
      ],
      "settings": {
        "foreground": "#D4A857"
      }
    },
    {
      "scope": [
        "storage.modifier",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#D4A857",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#C8B07C"
      }
    },
    {
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#C8B07C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "meta.function-call.object"
      ],
      "settings": {
        "foreground": "#6BAFC2"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#D6D2C4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#C8B07C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant"
      ],
      "settings": {
        "foreground": "#C88A9A"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "variable.language.special",
        "variable.parameter.function.language.special",
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": {
        "foreground": "#C88A9A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#8CB87A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.escape",
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#CF7B5F"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D4A857"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
